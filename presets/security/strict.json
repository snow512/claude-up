{
  "level": "strict",
  "description": "Strict security — production code, team collaboration",
  "enforce_chmod_0600": true,
  "providers": {
    "claude": {
      "deny": [
        "Bash(rm -rf:*)",
        "Bash(git push --force:*)",
        "Bash(git push -f:*)",
        "Bash(git reset --hard:*)",
        "Bash(git clean -f:*)",
        "Bash(git checkout -- .:*)",
        "Bash(git branch -D:*)",
        "Bash(chmod 777:*)",
        "Bash(curl * | bash:*)",
        "Bash(curl * | sh:*)",
        "Bash(wget * | bash:*)",
        "Bash(eval:*)"
      ]
    },
    "gemini": {
      "policies": [
        { "toolName": "shell", "argsPattern": "rm\\s+-rf", "decision": "deny", "priority": 500 },
        { "toolName": "shell", "argsPattern": "git push.*(--force|-f)", "decision": "deny", "priority": 500 },
        { "toolName": "shell", "argsPattern": "git reset.*--hard", "decision": "deny", "priority": 500 },
        { "toolName": "shell", "argsPattern": "git clean.*-f", "decision": "deny", "priority": 500 },
        { "toolName": "shell", "argsPattern": "git checkout.*--\\s*\\.", "decision": "deny", "priority": 500 },
        { "toolName": "shell", "argsPattern": "git branch.*-D", "decision": "deny", "priority": 500 },
        { "toolName": "shell", "argsPattern": "chmod\\s+777", "decision": "deny", "priority": 600 },
        { "toolName": "shell", "argsPattern": "curl.*\\|\\s*(bash|sh)", "decision": "deny", "priority": 600 },
        { "toolName": "shell", "argsPattern": "wget.*\\|\\s*(bash|sh)", "decision": "deny", "priority": 600 },
        { "toolName": "shell", "argsPattern": "\\beval\\b", "decision": "deny", "priority": 600 }
      ]
    },
    "codex": {
      "sandbox_mode": "read-only"
    }
  }
}
